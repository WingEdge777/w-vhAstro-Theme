---
import { fmtTime } from "@/utils/index";
import type { ArchiveGroup } from "@/type/blog";
const { articleList } = Astro.props as { articleList: ArchiveGroup[] };
// 文章页面样式
import "./Archive.less";
---

<section class="vh-archive-main vh-animation vh-animation-init">
	<div class="archive-list">
		{
			articleList.map((i) => (
				<div class="archive-list-item">
					<p class="title">
						<em>{i.name}</em>
						<i />
						<span>{i.data.length}篇文章</span>
					</p>
					{i.data.map((post) => (
						<a href={`/article/${post.id}`}>
							<em>{fmtTime(post.date, "MM-DD")}</em>
							<i />
							<span class="vh-ellipsis">{post.title}</span>
							<cite class="vh-ellipsis">{(post.tags || []).map((tag) => `#${tag}`).join(" ")}</cite>
						</a>
					))}
				</div>
			))
		}
	</div>
</section>

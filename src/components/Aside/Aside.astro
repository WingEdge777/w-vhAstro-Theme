---
// 静态图片
// Svg 组件
import Svg from "@/components/Svg/Svg.astro";
// 时间处理
import { fmtTime } from "@/utils/index";
import { getDictionary } from "@/i18n/dictionaries";
import { getLocaleFromPathname, localizePath } from "@/i18n/routes";
import type { SiteLocale } from "@/i18n/config";
// 获取用户配置数据
import SITE_CONFIG from "@/config";
const { Avatar, Author, Motto, WebSites, GoogleAds, AsideShow } = SITE_CONFIG;
// 获取文章数据
import {
	getCategories,
	getTags,
	getRecommendArticles,
	getCountInfo,
} from "@/utils/getPostInfo";
const locale = getLocaleFromPathname(Astro.url.pathname);
const dict = getDictionary(locale);
// 分类列表
const categories = await getCategories(locale as SiteLocale);
// 热门标签
const tags = (await getTags(locale as SiteLocale)).slice(0, 16);
// 获取网站统计数据
const CountInfo = await getCountInfo(locale as SiteLocale);
// 最新文章
const recommendArticles = await getRecommendArticles(locale as SiteLocale);
// TOC
const { post, headings } = Astro.props;
const shouldShowToc = headings && headings.length > 0;
// Google 广告组件
import GoogleAd from "@/components/GoogleAd/GoogleAd.astro";
// 侧边栏样式
import "./Aside.less";
---

<aside class="vh-aside">
	<!-- 头像块 -->
	{
		AsideShow.WebSitesShow && (
			<section class="vh-aside-item user">
				<img
					class="vh-aside-avatar"
					src="/assets/images/lazy-loading.webp"
					data-vh-lz-src={Avatar}
					alt={Author}
				/>
				<span class="vh-aside-auther">{Author}</span>
				<p class="vh-aside-motto">{Motto}</p>
				<section class="vh-aside-links">
					{WebSites.map((item) => (
						<a
							class="vh-aside-links-item"
							href={item.link}
							title={item.text}
							target="_blank"
							rel="noopener nofollow"
						>
							<Svg src={item.icon} />
						</a>
					))}
				</section>
				<section class="vh-aside-info">
					<div class="art-item count">
						<span>{CountInfo.ArticleCount}</span>
						<p>{dict.aside.articleCount}</p>
					</div>
					<div class="cat-item count">
						<span>{CountInfo.CategoryCount}</span>
						<p>{dict.aside.categoryCount}</p>
					</div>
					<div class="tag-item count">
						<span>{CountInfo.TagCount}</span>
						<p>{dict.aside.tagCount}</p>
					</div>
				</section>
				<canvas class="vh-aside-canvas" width="888" height="1888" />
			</section>
		)
	}
	<!-- 分类块 -->
	{
		AsideShow.CategoriesShow && (
			<section class="vh-aside-item cat">
				<h3>
					<bold>{dict.aside.categories}</bold>
				</h3>
				<div class="vh-aside-cat">
					{categories
						.sort((a: any, b: any) => b.count - a.count)
						.map((i) => (
							<a href={localizePath(`/categories/${i.title}`, locale)}>
								<span>{i.title}</span>
								<i>{i.count}</i>
							</a>
						))}
				</div>
			</section>
		)
	}

	<!-- 标签块 -->
	{
		AsideShow.TagsShow && (
			<section class="vh-aside-item tags">
				<h3>{dict.aside.popularTags}</h3>
				<div class="vh-aside-tags">
					{tags.map((i) => (
						<a href={localizePath(`/tag/${i[0]}`, locale)}>
							<span>{i[0]}</span>
							<em>{i[1]}</em>
						</a>
					))}
				</div>
			</section>
		)
	}

	<section class="sticky-aside vh-animation vh-animation-init">
		<!-- 最新文章块 -->
		{
			recommendArticles.length && AsideShow.recommendArticleShow && (
				<section class="vh-aside-item articles">
					<h3>{dict.aside.recommendArticles}</h3>
					<div class="vh-aside-articles">
						{recommendArticles.map((i, idx) => (
							<a href={i.href}>
								<span>
									{idx < 3 ? (
										<i>{idx + 1}</i>
									) : (
										<em>{idx + 1}.</em>
									)}
									<cite class="vh-ellipsis">{i.title}</cite>
								</span>
								<time>{fmtTime(i.date, "YYYY-MM-DD A", locale)}</time>
							</a>
						))}
					</div>
				</section>
			)
		}
		{
			shouldShowToc && (
				<nav class="vh-aside-item toc">
					<h3>{dict.aside.toc}</h3>
					<div class="vh-aside-toc">
						{headings.map(
							(h: { depth: number; slug: string; text: string }) => (
								<a href={`#${h.slug}`}>
									<span class={`toc-level-${h.depth}`}>
										{h.text.replace(/^#+\s*/, '')}
									</span>
								</a>
							),
						)}
					</div>
				</nav>
			)
		}
		<!-- 谷歌广告块 -->
		{
			GoogleAds.ad_Client && GoogleAds.asideAD_Slot && (
				<section class="vh-aside-item ad">
					<h3>{dict.aside.ad}</h3>
					<GoogleAd
						className="vh-aside-ad"
						slotID={GoogleAds.asideAD_Slot}
					/>
				</section>
			)
		}
	</section>
</aside>

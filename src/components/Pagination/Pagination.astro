---
const { data } = Astro.props;
// 处理页码
import { fmtPage } from "@/utils/index";
import { getDictionary } from "@/i18n/dictionaries";
import { getLocaleFromPathname } from "@/i18n/routes";
// 翻页组件样式
import "./Pagination.less";

const locale = getLocaleFromPathname(Astro.url.pathname);
const dict = getDictionary(locale);
---

<section class="vh-art-page">
	<!-- 上一页 -->
	<a class={`vh-pagination-item${!data.prev ? " disabled" : ""}`} href={data.prev || "javascript:;"} title={dict.pagination.prev}>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M15 6l-6 6l6 6"></path></svg>
	</a>
	<!-- 首页 -->
	{
		data.first && data.prev && (
			<a class={`vh-pagination-item`} href={data.first} title={dict.pagination.first}>
				1
			</a>
		)
	}
	<!-- 总页的前一页 -->
	{
		(!data.next || !data.last) && data.prev && fmtPage(data.current) !== "2" && (
			<a class={`vh-pagination-item`} href={data.prev} title={dict.pagination.page(fmtPage(data.prev) || "1")}>
				{fmtPage(data.prev)}
			</a>
		)
	}
	<!-- 当前页 -->
	<a class="vh-pagination-item active" href="javascript:;" title={dict.pagination.page(fmtPage(data.current) || "1")}>{fmtPage(data.current) || "1"}</a>
	<!-- 第一页的后一页 -->
	{
		(!data.prev || !data.first) && data.next && fmtPage(data.last) !== "2" && (
			<a class="vh-pagination-item" href={data.next} title={dict.pagination.page(fmtPage(data.next) || "1")}>
				{fmtPage(data.next)}
			</a>
		)
	}
	<!-- 总页 -->
	{
		data.next && data.last && (
			<a class={`vh-pagination-item`} href={data.last} title={dict.pagination.page(fmtPage(data.last) || "1")}>
				{fmtPage(data.last)}
			</a>
		)
	}
	<!-- 下一页 -->
	<a class={`vh-pagination-item${!data.next ? " disabled" : ""}`} href={data.next || "javascript:;"} title={dict.pagination.next}>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M9 6l6 6l-6 6"></path></svg>
	</a>
</section>

---
const { prev, next } = Astro.props;
import "./PrevNextArticle.less";
---

<section class="vh-otarticle">
	<a class="art-item" style={prev.cover ? `background-image: url('${prev.cover}')`:''} href={prev.href}><span class="vh-ellipsis line-2">{prev.title}</span></a>
	<a class="art-item" style={next.cover ? `background-image: url('${next.cover}')`:''} href={next.href}><span class="vh-ellipsis line-2">{next.title}</span></a>
</section>
